
---
import { Modal, ModalHeader, ModalBody, } from 'free-astro-components'
---


<Modal id="contact-modal" class=" contact relative mx-auto mt-10" size="lg">
<ModalHeader class="text-center">

<img class="h-8 mx-auto my-4" src="./logo.svg" alt="Logo" />
<h4>Contact Us</h4>
<p>We'll be happy to hear from you!</p>
</ModalHeader>
<ModalBody>
<form id="contact" data-netlify="true" netlify-honeypot name="contact" method="POST" action="/success">
<p class="hidden"><label>Don’t fill this out if you’re human: <input name="bot-field" /></label></p>
<input type="hidden" name="contact" value="contact" />

<div class="mb-4">
<label class="block text-gray-700 text-sm/6 font-medium mb-1.5" for="firstname">
First Name
</label>
<input id="first-name" class=" w-full bg-white rounded-md outline-1 outline-gray-300 p-1.5 text-sm/6 text-gray-700 placeholder:text-gray-400 focus:outline-none" type="text" placeholder="First Name" required>
</div>
<div class="mb-4">
<label class="block text-gray-700 text-sm/6 font-medium mb-1.5" for="lastname">
Last Name
</label>
<input id="last-name" class=" w-full bg-white rounded-md outline-1 outline-gray-300 p-1.5  text-sm/6 text-gray-700 placeholder:text-gray-400 focus:outline-none" type="text" placeholder="Last Name" required>
</div>
<div class="mb-4">
<label class="block text-gray-700 text-sm font-medium mb-1.5" for="email">
Email
</label>
<input id="email" class=" w-full bg-white rounded-md outline-1 outline-gray-300 p-1.5 text-sm/6 text-gray-700 placeholder:text-gray-400 focus:outline-none" type="text" placeholder="Email" required>
</div>
<div class="mb-4">
<label class="block text-gray-700 text-sm font-medium mb-1.5" for="phone">
Phone
</label>
<input id="phone" class=" w-full bg-white rounded-md outline-1 outline-gray-300 p-1.5 text-sm/6 text-gray-700 placeholder:text-gray-400 focus:outline-none" type="text" placeholder="Phone" required>
</div>
<div class="mb-4">
<label class="block text-gray-700 text-sm font-medium mb-1.5" for="message">
Message
</label>
<textarea id="message name="message" rows="3" class="block w-full rounded-md bg-white p-1.5 text-sm/6 text-gray-900 outline-1  outline-gray-300 placeholder:text-gray-400 sm:text-sm/6" placeholder="Message" required></textarea>
</div>

<div class="p-4 text-center">
<button type="submit" class="btn btn-neutral mx-auto">Send Message</button>
</div>

</form>
</ModalBody>
</Modal>










